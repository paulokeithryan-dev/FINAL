    sectionList.Parent = tabContent

    -- Hover effects
    tabBtn.MouseEnter:Connect(function()
        tabBtn.BackgroundColor3 = ColorScheme.SectionBg
    end)
    tabBtn.MouseLeave:Connect(function()
        if CurrentTabContent == tabContent then
            tabBtn.BackgroundColor3 = ColorScheme.Accent
        else
            tabBtn.BackgroundColor3 = ColorScheme.DarkBg
        end
    end)

    -- Click to switch tab
    tabBtn.MouseButton1Click:Connect(function()
        -- Hide all tab contents
        for _, otherTab in ipairs(Tabs) do
            otherTab.Content.Visible = false
            otherTab.Btn.BackgroundColor3 = ColorScheme.DarkBg
            otherTab.TextLabel.TextColor3 = ColorScheme.Text
        end
        -- Show this tab
        tabContent.Visible = true
        tabBtn.BackgroundColor3 = ColorScheme.Accent
        tabBtn:FindFirstChildOfClass("TextLabel", true).TextColor3 = Color3.fromRGB(255, 255, 255)
        CurrentTabContent = tabContent
    end)

    local tabData = { Content = tabContent, Btn = tabBtn, TextLabel = textLabel }
    table.insert(Tabs, tabData)

    -- Set first tab as active
    if #Tabs == 1 then
        tabContent.Visible = true
        tabBtn.BackgroundColor3 = ColorScheme.Accent
        textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        CurrentTabContent = tabContent
    end

    if callback then callback(tabContent, contentList) end

    return tabData
end

