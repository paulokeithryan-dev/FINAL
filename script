    -- ============================================================
    -- SECTION 4: ROBUST NETWORKING ENGINE (PACKET-BASED)
    -- ============================================================
    local NetworkRemote = nil
    local PacketResolved = false

    local function resolveNetworkRemote()
        if PacketResolved and NetworkRemote then return NetworkRemote end

        local strategies = {
            function() return ReplicatedStorage:FindFirstChild("Network") end,
            function() return ReplicatedStorage:FindFirstChild("Remote") end,
            function() return ReplicatedStorage:FindFirstChild("Packets") end,
            function()
                for _, child in ipairs(ReplicatedStorage:GetChildren()) do
                    if child:IsA("RemoteEvent") then return child end
                end
                return nil
            end,
            function()
                for _, child in ipairs(ReplicatedStorage:GetChildren()) do
                    if child:IsA("RemoteFunction") then return child end
                end
                return nil
            end,
        }

        for _, strategy in ipairs(strategies) do
            local found = pcall(strategy)
            if found then
                NetworkRemote = found
                PacketResolved = true
                return found
            end
        end

        return nil
    end

    local function FirePacket(packetName, ...)
        local remote = resolveNetworkRemote()
        if not remote then return false, "No network remote found" end

        local success, result = pcall(function()
            if remote:IsA("RemoteFunction") then
                return remote:InvokeServer(packetName, ...)
            elseif remote:IsA("RemoteEvent") then
                remote:FireServer(packetName, ...)
                return true
            end
        end)

        return success, result
    end

    local function FireAndWait(packetName, ...)
        local remote = resolveNetworkRemote()
        if not remote then return false, nil end

        local success, result = pcall(function()
            return remote:InvokeServer(packetName, ...)
        end)

        return success, result
    end

