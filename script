local function configureCustomButton(button, name, color)
    button.Name = name .. "Button"
    button.Text = name
    button.Size = UDim2.new(0, 120, 0, 40)
    button.BackgroundColor3 = color
    button.Font = Enum.Font.SourceSansBold
    button.TextSize = 18
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    
    -- Hardening UI attributes via layout signals
    button:GetPropertyChangedSignal("BackgroundColor3"):Connect(function()
        if button.BackgroundColor3 ~= color then
            button.BackgroundColor3 = color
        end
    end)
end

local function safeInject(teleportContainer)
    if not teleportContainer or teleportContainer:FindFirstChild("GearsButton") then 
        return 
    end
    
    print("[Premium UI] Teleport target discovered. Injecting custom UI nodes...")
    
    -- Instantiate Gears Button
    local gearsBtn = Instance.new("TextButton")
    configureCustomButton(gearsBtn, "Gears", Color3.fromRGB(230, 50, 50))
    gearsBtn.Parent = teleportContainer
    
    -- Instantiate Props Button
    local propsBtn = Instance.new("TextButton")
    configureCustomButton(propsBtn, "Props", Color3.fromRGB(50, 150, 230))
    propsBtn.Parent = teleportContainer
    
    -- Action Handlers
    gearsBtn.MouseButton1Click:Connect(function()
        print("[Premium UI] Loading Tool Tracking / Asset Inventory Matrix...")
    end)
    
    propsBtn.MouseButton1Click:Connect(function()
        print("[Premium UI] Initializing Prop Subsystems...")
    end)
end

-- Dynamic structural scan and listener hooks
local function initializeUIEngine()
    local existingContainer = PlayerGui:FindFirstChild("TeleportButtons", true)
    if existingContainer then
        safeInject(existingContainer)
    end
    
    PlayerGui.DescendantAdded:Connect(function(descendant)
        if descendant.Name == "TeleportButtons" then
            task.defer(safeInject, descendant)
        end
    end)
end

