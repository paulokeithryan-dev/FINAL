                if wLabel then
                    local w = WeatherState.Active or "Clear"
                    local wc = WeatherEvents[w] and WeatherEvents[w].color or "#FFFFFF"
                    pcall(function() wLabel.Text = string.format('Weather: <font color="%s">%s</font>', wc, w) end)
                end

                local tLabel = TimeCycleState.StatusLabel
                if tLabel then
                    pcall(function() tLabel.Text = string.format("Time: %s (%s)", TimeCycleState.CurrentPhase, TimeCycleState.CurrentMoon) end)
                end

                if UI.ActiveLabel then
                    local activeCount = 0
                    for k, v in pairs(Config) do
                        if type(v) == "boolean" and v then activeCount = activeCount + 1 end
                    end
                    pcall(function() UI.ActiveLabel.Text = "Active: " .. activeCount end)
                end
            end
        end)
    end

    -- ============================================================
    -- SECTION 29: MOON EVENT DETECTION
    -- ============================================================
    local function startMoonDetection()
        task.spawn(function()
            while true do
                task.wait(30)
                local clockTime = Lighting.ClockTime
                if clockTime then
                    if clockTime >= 20 or clockTime <= 4 then
                        TimeCycleState.IsNight = true
                        TimeCycleState.CurrentPhase = "Night"

                        local ambient = Lighting.Ambient
                        local r, g, b = ambient.R, ambient.G, ambient.B

                        if r > 0.8 and g < 0.2 and b < 0.2 then
                            TimeCycleState.CurrentMoon = "Bloodmoon"
                            if Config.MoonEventAlertEnabled then
                                print("[MOON]: Bloodmoon detected! Enabling combat mode...")
                            end
                        elseif r > 0.8 and g > 0.6 and b < 0.3 then
                            TimeCycleState.CurrentMoon = "Goldmoon"
                            if Config.MoonEventAlertEnabled then
                                print("[MOON]: Goldmoon detected!")
                            end
                            if Config.GoldmoonAutoHarvest then autoHarvestMature() end
                        elseif r > 0.5 and g < 0.3 and b > 0.5 then
                            TimeCycleState.CurrentMoon = "Rainbow Moon"
                            if Config.MoonEventAlertEnabled then
                                print("[MOON]: Rainbow Moon detected!")
                            end
                        elseif r > 0.3 and g < 0.2 and b > 0.8 then
                            TimeCycleState.CurrentMoon = "Mega Moon"
                            if Config.MegaMoonAlertEnabled then
                                print("[MOON]: Mega Moon detected!")
                            end
                        else
                            TimeCycleState.CurrentMoon = "Moon"
                        end
                    else
                        TimeCycleState.IsNight = false
                        local hour = math.floor(clockTime)
                        if hour >= 17 then
                            TimeCycleState.CurrentPhase = "Sunset"
                        else
                            TimeCycleState.CurrentPhase = "Day"
                        end
                        TimeCycleState.CurrentMoon = "Moon"
                    end
                end
            end
        end)
    end

    -- ============================================================
    -- SECTION 30: MAIN INITIALIZATION
    -- ============================================================
    loadConfig()
    buildUI()
    monitorWeather()
    startStatusUpdates()
    startMoonDetection()

    RunService.Heartbeat:Connect(function(dt)
        runSafe(function() runAllLoops(dt) end, "MainLoop")
    end)

    task.spawn(function()
        while true do
            task.wait(60)
            pcall(saveConfig)
        end
    end)

    if Config.CmdrLoggerEnabled then
        task.spawn(function()
            pcall(function()
                local cmdr = ReplicatedStorage:FindFirstChild("Cmdr")
                if cmdr and cmdr:IsA("RemoteEvent") then
                    local originalFire = cmdr.FireServer
                    cmdr.FireServer = function(self, ...)
                        local args = {...}
                        print("[CMDR]: " .. tostring(args[1]))
                        return originalFire:Invoke(self, ...)
                    end
                end
            end)
        end)
    end

    if Config.SkipLoadingScreen then
        task.spawn(function()
            local loadingScreen = game.CoreGui:FindFirstChild("LoadingScreen")
                or game.CoreGui:FindFirstChild("Loader")
            if loadingScreen then pcall(function() loadingScreen:Destroy() end) end
        end)
    end

    if Config.BypassGameplayPaused then
        task.spawn(function()
            local pauser = game.CoreGui:FindFirstChild("GameplayPaused")
                or game.CoreGui:FindFirstChild("PausedScreen")
            if pauser then pcall(function() pauser:Destroy() end) end
        end)
    end

    print("=================================================================")
    print("  Garden Tycoon — Ultra Control Suite v10.1")
    print("  Zero-Error Design | User-First | Compiler-Integrated")
    print("=================================================================")
    print(string.format("  Tabs: %d | Packets: %d | Database: %d pets", #allTabs, #Packets, #PetDatabase))
    print("=================================================================")

end

