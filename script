    CardTitle.TextSize = 13
    CardTitle.Font = Enum.Font.GothamMedium
    CardTitle.TextXAlignment = Enum.TextXAlignment.Left
    CardTitle.Parent = Card
    
    local DropdownBtn = Instance.new("TextButton")
