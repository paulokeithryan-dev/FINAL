--- Get the local player's garden model
local function getMyGarden()
    local gardens = Workspace:FindFirstChild("Gardens")
    if not gardens then return nil end

    for _, garden in ipairs(gardens:GetChildren()) do
        if garden.Name == LocalPlayer.Name
            or string.find(garden.Name, tostring(LocalPlayer.UserId))
            or garden:GetAttribute("Owner") == LocalPlayer.Name
            or garden:GetAttribute("OwnerID") == LocalPlayer.UserId then
            return garden
        end
        -- Check value-based ownership
        for _, child in ipairs(garden:GetDescendants()) do
            if child:IsA("ValueBase") and tostring(child.Value) == tostring(LocalPlayer.UserId) then
                return garden
            end
        end
    end
    return nil
end

--- Check if a garden belongs to the local player
local function isMyGarden(garden)
    if garden.Name == LocalPlayer.Name or string.find(garden.Name, tostring(LocalPlayer.UserId)) then
        return true
