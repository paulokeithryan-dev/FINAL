--- Detect when another player is attempting to steal from you
local function detectStealAttempts()
    -- Monitor ProximityPrompt triggers near your fruits
    local myGarden = getMyGarden()
    if not myGarden then return end

    local fruits = myGarden:FindFirstChild("Fruits")
    if not fruits then return end

    for _, fruit in ipairs(fruits:GetChildren()) do
        local prompts = fruit:GetChildrenOfType("ProximityPrompt")
        for _, prompt in ipairs(prompts) do
            local triggeredBy = prompt:FindFirstChildOfClass("ObjectValue")
            if triggeredBy and triggeredBy.Value ~= LocalPlayer then
                -- Another player is trying to interact with our fruit
                if Config.StealProtectionEnabled then
                    local thief = triggeredBy.Value
                    print(string.format("[STEAL GUARD]: %s is attempting to access fruit: %s", thief.Name, fruit.Name))

                    -- Intervene by positioning near the fruit and using shovel
                    interveneAgainstStealer(thief, fruit)
                end
            end
        end
    end
end

--- Physically intervene against a fruit stealer
local function interveneAgainstStealer(thiefPlayer, fruitModel)
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    local thiefRoot = thiefPlayer.Character and thiefPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not thiefRoot then return end

    -- Dash to the fruit/stealer
    local targetPos = fruitModel:FindFirstChildOfClass("BasePart")
    if targetPos then
        if activeTween then pcall(function() activeTween:Cancel() end) end
        local dist = (rootPart.Position - targetPos.Position).Magnitude
        local speed = Config.CombatDashSpeed
        local duration = dist / speed
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad)
        activeTween = TweenService:Create(rootPart, tweenInfo, {CFrame = targetPos.CFrame * CFrame.new(0, 2, 0)})
        activeTween:Play()
    end

    -- Use shovel to strike
    local shovel = character:FindFirstChild("Shovel") or LocalPlayer.Backpack:FindFirstChild("Shovel")
    if shovel then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid and shovel.Parent == LocalPlayer.Backpack then
            humanoid:EquipTool(shovel)
            task.wait(0.05)
        end
        shovel:Activate()
    end

    -- Also fire VirtualInputManager for the game's click-to-strike mechanic
    local camera = Workspace.CurrentCamera
    if camera then
        local screenX, screenY = camera:WorldToScreenPoint(thiefRoot.Position)
        if screenX then
            VirtualInputManager:SendMouseButtonEvent(screenX, screenY, 0, true, game, 0)
            task.wait(0.03)
            VirtualInputManager:SendMouseButtonEvent(screenX, screenY, 0, false, game, 0)
        end
    end
end

