local function loadConfig()
    local success, json = pcall(function()
        local fs = readfile or function() end
        return HttpService:JSONDecode(fs(FILE_NAME))
    end)
    if success and type(json) == "table" then
        for k, v in pairs(json) do
            if Config[k] ~= nil then
                Config[k] = v
            end
        end
        print("[CONFIG]: Loaded from " .. FILE_NAME)
    else
        print("[CONFIG]: No existing config found, using defaults")
    end
end

local function saveConfig()
    local success, json = pcall(function()
        return HttpService:JSONEncode(Config)
    end)
    if success then
        local fs = writefile or function() end
        fs(FILE_NAME, json)
    end
end

