    shops = 30,           -- Slow: shop restocks
    pets = 5,             -- Medium: pet management
    environment = 10,     -- Slow: performance
    garden = 3,           -- Medium: garden maintenance
}

local function runAllBackgroundLoops(dt)
    local now = os.clock()

    -- Pet hunt protection (fastest loop)
    if now - loopTimers.petHunt >= loopIntervals.petHunt then
        loopTimers.petHunt = now
        runPetHuntProtection()
        if Config.ProtectionEnabled then
            detectStealAttempts()
        end
    end

    -- Auto-harvest
    if now - loopTimers.harvest >= loopIntervals.harvest then
        loopTimers.harvest = now
        if Config.AutoHarvestMature then autoHarvestMatureFruits() end
        autoHarvestSpecialFruits()
        if Config.AutoSellHarvested then autoSellHarvestedFruit() end
        if Config.AutoPromoteFruit then autoPromoteFruits() end
    end

    -- Weather farming
    if now - loopTimers.weather >= loopIntervals.weather then
        loopTimers.weather = now
        if Config.WeatherFarmingMode then runWeatherFarming() end
        if Config.WeatherMonitorEnabled then
            -- Weather state is already updated via ChildAdded
        end
    end

    -- ESP rendering
    if now - loopTimers.esp >= loopIntervals.esp then
        loopTimers.esp = now
        -- Scan workspace for new pets/fruits
        local petFolder = Workspace:FindFirstChild("WildPets") or Workspace:FindFirstChild("Pets") or Workspace:FindFirstChild("Animals")
        if petFolder then
            for _, petModel in ipairs(petFolder:GetChildren()) do
                if not ActiveESP[petModel] then
                    renderPetESP(petModel)
                end
            end
        end

        -- Scan fruits
        if Config.ESPShowFruit then
            local myGarden = getMyGarden()
            if myGarden then
                local fruits = myGarden:FindFirstChild("Fruits")
                if fruits then
                    for _, fruit in ipairs(fruits:GetChildren()) do
                        if not ActiveESP[fruit] then
                            renderFruitESP(fruit)
                        end
                    end
                end
            end
        end
    end

    -- Steal detection
    if now - loopTimers.steal >= loopIntervals.steal then
        loopTimers.steal = now
        if Config.StealProtectionEnabled then
            detectStealAttempts()
        end
    end

    -- Guild management
    if now - loopTimers.guild >= loopIntervals.guild then
        loopTimers.guild = now
        if Config.GuildEnabled then updateGuildState() end
    end

    -- Skill points
    if now - loopTimers.skills >= loopIntervals.skills then
        loopTimers.skills = now
        autoSpendSkillPoints()
    end

    -- Economy (daily deals, double or nothing)
    if now - loopTimers.economy >= loopIntervals.economy then
        loopTimers.economy = now
        autoUseDailyDeals()
        autoDoubleOrNothing()
    end

    -- Auction sniper
    if now - loopTimers.auction >= loopIntervals.auction then
        loopTimers.auction = now
        runAuctionSniper()
    end

    -- Auto-join pet hunt
    if now - loopTimers.autoJoin >= loopIntervals.autoJoin then
        loopTimers.autoJoin = now
        runAutoJoinPetHunt()
    end

    -- Plant care (watering, fertilizing)
    if now - loopTimers.plants >= loopIntervals.plants then
        loopTimers.plants = now
        if Config.AutoWaterEnabled then autoWaterPlants() end
        if Config.AutoFertilizeEnabled then autoFertilizePlants() end
        if Config.AutoMutatePlants then autoMutatePlants() end
    end

    -- Mailbox
    if now - loopTimers.mail >= loopIntervals.mail then
        loopTimers.mail = now
        if Config.AutoClaimMail then autoClaimMail() end
        if Config.GiftBestToGuild then autoGiftBestToGuild() end
        if Config.AutoGiftToSpecificPlayer then autoGiftToPlayer() end
    end

    -- Shop auto-buy
    if now - loopTimers.shops >= loopIntervals.shops then
        loopTimers.shops = now
        if Config.SeedShopAutoBuy then autoBuyRestockedSeeds() end
        if Config.EggShopAutoBuy then autoBuyEggs() end
        if Config.GearShopAutoBuy then autoBuyGear() end
    end

    -- Pet management
    if now - loopTimers.pets >= loopIntervals.pets then
        loopTimers.pets = now
        if Config.AutoEquipBestPet then autoEquipBestPet() end
        if Config.WildPetAutoTame then autoTameWildPets() end
    end

    -- Environment
    if now - loopTimers.environment >= loopIntervals.environment then
        loopTimers.environment = now
        applyFullBright()
        removeOtherGardens()
        if Config.AutoReduceLag then autoReduceLag() end
    end

    -- Garden maintenance
    if now - loopTimers.garden >= loopIntervals.garden then
        loopTimers.garden = now
        if Config.AutoPlaceSprinklers then autoPlaceSprinklers() end
        if Config.AutoPlaceRakes then autoPlaceRakes() end
        if Config.AutoPlantEnabled then autoPlantSeeds() end
        if Config.AutoExpandGarden then autoExpandGarden() end
        if Config.AutoCollectOffline then autoCollectOfflineGrowth() end
    end
end
