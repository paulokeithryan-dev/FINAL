local function rotateServerInstance()
    print("[PET_FINDER]: Scanning global public rooms for low player counts...")
    
    local apiURL = string.format("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100", tostring(PLACE_ID))
    local fetchSuccess, serverData = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(apiURL))
    end)
    
    if fetchSuccess and serverData and serverData.data then
        local serverList = serverData.data
        local priorityServers = {}
        local backupServers = {}
        
        for _, server in pairs(serverList) do
            if server.id and server.id ~= game.JobId and server.playing then
                if server.playing >= 1 and server.playing <= Config.MaxServerPlayers then
                    table.insert(priorityServers, server)
                elseif server.playing < server.maxPlayers then
                    table.insert(backupServers, server)
                end
            end
        end
        
        -- Randomize arrays to distribute across available targets
        math.randomseed(os.time())
        for i = #priorityServers, 2, -1 do
            local j = math.random(i)
            priorityServers[i], priorityServers[j] = priorityServers[j], priorityServers[i]
        end
        
        for _, server in pairs(priorityServers) do
            print(string.format("[PET_FINDER]: Selected low-occupancy server (%d players). Requesting routing access...", server.playing))
            task.wait(0.5)
            local teleportSuccess, teleportErr = pcall(function()
                TeleportService:TeleportToPlaceInstance(PLACE_ID, server.id, LocalPlayer)
            end)
            if teleportSuccess then return end
        end
        
        -- Fallback sequence to regular public instances
        print("[PET_FINDER]: No immediate priority low-player instances open. Dropping to standard index array...")
        for i = #backupServers, 2, -1 do
            local j = math.random(i)
            backupServers[i], backupServers[j] = backupServers[j], backupServers[i]
        end
        
        for _, server in pairs(backupServers) do
            task.wait(0.5)
            local teleportSuccess, teleportErr = pcall(function()
                TeleportService:TeleportToPlaceInstance(PLACE_ID, server.id, LocalPlayer)
            end)
            if teleportSuccess then return end
        end
    end
    
    print("[PET_FINDER]: Public routing exhausted. Executing standard security jump...")
    pcall(function()
        TeleportService:Teleport(PLACE_ID, LocalPlayer)
    end)
end

