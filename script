    local function getMyGarden()
        local gardens = Workspace:FindFirstChild("Gardens")
        if not gardens then return nil end

        for _, garden in ipairs(gardens:GetChildren()) do
            local name = garden.Name:lower()
            local lpName = LocalPlayer.Name:lower()
            local lpId = tostring(LocalPlayer.UserId)

            if name == lpName or string.find(name, lpName) or string.find(name, lpId) then
                return garden
            end
            if garden:GetAttribute("Owner") == LocalPlayer.Name
                or tostring(garden:GetAttribute("OwnerID")) == lpId then
                return garden
            end
            for _, child in ipairs(garden:GetDescendants()) do
                if child:IsA("ValueBase") and tostring(child.Value) == lpId then
                    return garden
                end
            end
        end
        return nil
    end

    local function isMyGarden(garden)
        if not garden then return false end
        local name = garden.Name:lower()
        local lpName = LocalPlayer.Name:lower()
        local lpId = tostring(LocalPlayer.UserId)

        if name == lpName or string.find(name, lpName) or string.find(name, lpId) then
            return true
        end
        if garden:GetAttribute("Owner") == LocalPlayer.Name
            or tostring(garden:GetAttribute("OwnerID")) == lpId then
            return true
        end
        for _, child in ipairs(garden:GetDescendants()) do
            if child:IsA("ValueBase") and tostring(child.Value) == lpId then
                return true
            end
        end
        return false
    end

