    function AutomationCore:GetPlayerTycoon()
        local possibleFolders = {
            Workspace:FindFirstChild("Tycoons"),
            Workspace:FindFirstChild("Gardens"),
            Workspace:FindFirstChild("Plots")
        }

        for _, folder in ipairs(possibleFolders) do
            if folder then
                for _, tycoon in ipairs(folder:GetChildren()) do
                    local ownerAttr = tycoon:GetAttribute("Owner") or tycoon:GetAttribute("OwnerID")
                    local ownerVal = tycoon:FindFirstChild("Owner") or tycoon:FindFirstChild("Player")
                    
                    if tostring(ownerAttr) == LocalPlayer.Name or tostring(ownerAttr) == tostring(LocalPlayer.UserId) then
                        return tycoon
                    end
                    if ownerVal and (ownerVal.Value == LocalPlayer or ownerVal.Value == LocalPlayer.Name) then
                        return tycoon
                    end
                end
            end
        end

        -- Spatial proximity fallback
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local pos = LocalPlayer.Character.HumanoidRootPart.Position
            local nearest, dist = nil, math.huge
            for _, folder in ipairs(possibleFolders) do
                if folder then
                    for _, tycoon in ipairs(folder:GetChildren()) do
                        local part = tycoon:FindFirstChildWhichIsA("BasePart", true)
                        if part then
                            local d = (part.Position - pos).Magnitude
                            if d < dist and d < 150 then
                                dist = d
                                nearest = tycoon
                            end
                        end
                    end
                end
            end
            return nearest
        end

        return nil
    end

    function AutomationCore:GetPlantsAndPlots(tycoon)
        if not tycoon then return {}, {} end
        local plots = {}
        local plants = {}

        local plotsFolder = tycoon:FindFirstChild("Plots") or tycoon:FindFirstChild("Dirt") or tycoon
        local plantsFolder = tycoon:FindFirstChild("Plants") or tycoon:FindFirstChild("Crops") or tycoon

        if plotsFolder then
            for _, p in ipairs(plotsFolder:GetChildren()) do
                if p:IsA("BasePart") or string.find(string.lower(p.Name), "plot") then
                    table.insert(plots, p)
                end
            end
        end

        if plantsFolder then
            for _, p in ipairs(plantsFolder:GetChildren()) do
                if (p:IsA("Model") or p:IsA("BasePart")) and not string.find(string.lower(p.Name), "plot") then
                    table.insert(plants, p)
                end
            end
        end

        return plots, plants
    end

    function AutomationCore:RunAgricultureRoutine()
        if not (Config.AutoPlantEnabled or Config.AutoWaterEnabled or Config.AutoHarvestMature or Config.AutoHarvestElectric or Config.AutoHarvestFrozen or Config.AutoHarvestStarstruck or Config.AutoHarvestAurora or Config.AutoHarvestIgnited or Config.AutoFertilizeEnabled or Config.AutoMutatePlants) then
            return
        end

        local tycoon = self:GetPlayerTycoon()
        if not tycoon then return end

        local plots, plants = self:GetPlantsAndPlots(tycoon)

        -- 1. Plot Management (Planting & Watering)
        for _, plot in ipairs(plots) do
            local isOccupied = plot:GetAttribute("Occupied") or plot:GetAttribute("PlantId") or plot:GetAttribute("HasPlant")
            local waterLevel = plot:GetAttribute("Water") or plot:GetAttribute("Moisture") or plot:GetAttribute("WaterLevel")
            
            if Config.AutoWaterEnabled and type(waterLevel) == "number" and waterLevel < 30 then
                NetworkEngine:Fire("GardenWaterPlant", plot.Position or plot.Name)
                NetworkEngine:Fire("WaterPlot", plot.Name)
                task.wait(0.01)
            end

            if Config.AutoPlantEnabled and (not isOccupied or isOccupied == "" or isOccupied == false) then
                NetworkEngine:Fire("GardenPlantSeed", Config.TargetSeedForAutoBuy, plot.Position or plot.Name)
                NetworkEngine:Fire("PlantSeed", plot.Name, Config.TargetSeedForAutoBuy)
                task.wait(0.02)
            end
            
            if Config.AutoFertilizeEnabled and isOccupied then
                NetworkEngine:Fire("GardenFertilize", plot.Position or plot.Name)
            end
            
            if Config.AutoMutatePlants and isOccupied then
                NetworkEngine:Fire("GardenMutatePlant", plot.Position or plot.Name)
            end
        end

        -- 2. Plant Management (Harvesting)
        for _, plant in ipairs(plants) do
            local isMature = plant:GetAttribute("Mature") or plant:GetAttribute("Ready") or plant:GetAttribute("Grown") or plant:FindFirstChild("Ready")
            local rarity = plant:GetAttribute("Rarity") or plant:GetAttribute("FruitRarity") or plant:GetAttribute("Type") or "Common"
            local rarityLower = string.lower(tostring(rarity))
            
            local shouldHarvest = false
            
            if Config.AutoHarvestMature and isMature then shouldHarvest = true end
            if Config.AutoHarvestElectric and string.find(rarityLower, "electric") then shouldHarvest = true end
            if Config.AutoHarvestFrozen and string.find(rarityLower, "frozen") then shouldHarvest = true end
            if Config.AutoHarvestStarstruck and string.find(rarityLower, "starstruck") then shouldHarvest = true end
            if Config.AutoHarvestAurora and string.find(rarityLower, "aurora") then shouldHarvest = true end
            if Config.AutoHarvestIgnited and string.find(rarityLower, "ignited") then shouldHarvest = true end

            if shouldHarvest then
                NetworkEngine:Fire("GardenHarvest", plant.Position or plant.Name)
                NetworkEngine:Fire("HarvestPlant", plant.Name)
                
                if Config.AutoSellHarvested then
                    task.wait(0.05)
                    local fruitName = plant:GetAttribute("FruitName") or plant.Name
                    NetworkEngine:Fire("SellItem", fruitName, 1)
                    NetworkEngine:Fire("SellFruit", fruitName)
                end
                task.wait(0.02)
            end
        end
    end

