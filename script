    local function runAllLoops(dt)
        local now = os.clock()

        if now - (LoopCounters.petHunt or 0) >= LoopIntervals.petHunt then
            LoopCounters.petHunt = now
            runSafe(runPetHuntProtection, "PetHunt")
            runSafe(detectStealAttempts, "Steal")
