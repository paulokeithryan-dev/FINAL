    local function autoHarvestMature()
        local fruits = getMyFruits()
        if #fruits == 0 then return end

        for _, fruit in ipairs(fruits) do
            local maturity = fruit:GetAttribute("Maturity")
                or fruit:GetAttribute("Growth")
                or fruit:GetAttribute("Ready")
            if maturity and (maturity == 1 or maturity == true or maturity == "Ready" or maturity == "Mature") then
                local pos = fruit:FindFirstChildOfClass("BasePart")
                if pos then
                    FirePacket(Packets.GardenHarvest.id, pos.Position)
                else
                    FirePacket(Packets.GardenHarvestAll.id)
                    break
                end
            end
        end
    end

