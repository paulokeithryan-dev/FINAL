                        ActiveESP[cachedModel] = nil
                    end
                end
                for _, petModel in ipairs(wildFolder:GetChildren()) do renderESPForModel(petModel) end
            end
        else
            if next(ActiveESP) ~= nil then clearAllESP() end
        end
    end
end)

