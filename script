local function saveConfig()
    local success, encoded = pcall(function() return HttpService:JSONEncode(Config) end)
    if success and writefile then
        writefile(FILE_NAME, encoded)
        print("[CONFIG]: Setup profile written safely to local disk partition.")
    end
end

local function loadConfig()
    if isfile and isfile(FILE_NAME) and readfile then
        local fileContents = readfile(FILE_NAME)
        local decodeSuccess, decodedTable = pcall(function() return HttpService:JSONDecode(fileContents) end)
        
        if decodeSuccess and type(decodedTable) == "table" then
            for key, value in pairs(decodedTable) do
                if type(value) == "table" and type(Config[key]) == "table" then
                    for subKey, subValue in pairs(value) do Config[key][subKey] = subValue end
                else
                    Config[key] = value
                end
            end
            
            local elements = {
                "PetHuntEnabled", "ProtectionEnabled", "AutoRemoveOtherGardens",
                "FullBright", "InfiniteZoom", "AntiFling", "LessKnockback", 
                "InstantPrompt", "BypassGameplayPaused", "ESPEnabled",
                "ESPSelectedPets", "ESPSelectedRarities", "ESPSelectedSizes",
                "TeleportMode", "ServerHopEnabled", "MaxServerPlayers"
            }
            for _, key in ipairs(elements) do
                if ToggleRegistry[key] then ToggleRegistry[key](Config[key]) end
            end
            for petName, isTargeted in pairs(Config.TargetPets) do
                if ToggleRegistry["Pet_" .. petName] then ToggleRegistry["Pet_" .. petName](isTargeted) end
            end
        end
    end
end

local function isMyGarden(garden)
    if garden.Name == LocalPlayer.Name or string.find(garden.Name, tostring(LocalPlayer.UserId)) then return true end
    if garden:GetAttribute("Owner") == LocalPlayer.Name or garden:GetAttribute("OwnerID") == LocalPlayer.UserId then return true end
    return false
end

local function removeOtherGardensInstantly()
    local gardensFolder = workspace:FindFirstChild("Gardens")
    if gardensFolder then
        for _, garden in ipairs(gardensFolder:GetChildren()) do
            if not isMyGarden(garden) then pcall(function() garden:Destroy() end) end
        end
    end
end

local function applyAggressiveLagReduction()
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
    end)
    for _, instance in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if instance:IsA("ParticleEmitter") or instance:IsA("Smoke") or instance:IsA("Sparkles") then
                instance:Destroy()
            elseif instance:IsA("Decal") or instance:IsA("Texture") then
                instance:Destroy()
            elseif instance:IsA("BasePart") then
                instance.CastShadow = false
                instance.Material = Enum.Material.SmoothPlastic
            end
        end)
    end
