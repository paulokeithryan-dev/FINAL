    local function executeInterception(thiefRoot, petRoot)
        local character = LocalPlayer.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if not rootPart or not humanoid then return end

        local shovel = character:FindFirstChild("Shovel") or LocalPlayer.Backpack:FindFirstChild("Shovel")
        if shovel and shovel.Parent == LocalPlayer.Backpack then
            humanoid:EquipTool(shovel)
            task.wait(0.02)
        end

        local strikePos = thiefRoot.CFrame * CFrame.new(0, 0, 1.2)
        
        if activeTween then pcall(function() activeTween:Cancel() end) end
        local speed = Config.CombatDashSpeed
        local distance = (rootPart.Position - strikePos.Position).Magnitude
        local duration = math.clamp(distance / speed, 0.05, 10)
        activeTween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = strikePos})
        activeTween:Play()
        activeTween.Completed:Wait()
        activeTween = nil

        if shovel then
            for i = 1, 10 do
                executeStrike(shovel)
                task.wait()
            end
        end

        local returnPos = petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0)
        if activeTween then pcall(function() activeTween:Cancel() end) end
        distance = (rootPart.Position - returnPos.Position).Magnitude
        duration = math.clamp(distance / speed, 0.05, 10)
        activeTween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = returnPos})
        activeTween:Play()
        activeTween.Completed:Wait()
        activeTween = nil
    end

    local function runPetHuntProtection()
        if not (Config.PetHuntEnabled or Config.ProtectionEnabled) then return end

        local rootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end

        local nearestPet, nearestDist = nil, math.huge
        local nearestThief, nearestThiefDist = nil, math.huge
        local isThreatened = false

        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer or not player.Character then continue end
            local thiefRoot = player.Character:FindFirstChild("HumanoidRootPart")
            if not thiefRoot then continue end

            local thiefDist = (thiefRoot.Position - rootPart.Position).Magnitude
            if thiefDist <= Config.ProtectionRadius then
                isThreatened = true
                if thiefDist < nearestThiefDist then
                    nearestThief = player
                    nearestThiefDist = thiefDist
                end

                for _, petModel in ipairs(player.Character:GetChildren()) do
                    local petRoot = petModel:FindFirstChild("RootPart")
                    if not petRoot then petRoot = petModel:FindFirstChildOfClass("BasePart") end
                    if not petRoot then continue end

                    local petName = petModel:GetAttribute("PetName") or petModel.Name
                    local cleanName = string.gsub(string.lower(petName), "%s+", "")

                    local isTarget = false
                    for _, pd in ipairs(PetDatabase) do
                        local dbKey = string.lower(string.gsub(pd[2], "%s+", ""))
                        local dbName = string.lower(string.gsub(pd[1], "%s+", ""))
                        if cleanName == dbKey or cleanName == dbName then
                            isTarget = true
                            break
                        end
                    end

                    if isTarget then
                        local petDist = (petRoot.Position - rootPart.Position).Magnitude
                        if petDist < nearestDist then
                            nearestPet = petRoot
                            nearestDist = petDist
                        end
                        renderPetESP(petModel)
                    end
                end
            end
        end

        if isThreatened and nearestPet and nearestThief then
            local thiefHRP = nearestThief.Character and nearestThief.Character:FindFirstChild("HumanoidRootPart")
            if thiefHRP then
                executeInterception(thiefHRP, nearestPet)
            end
        end
    end

