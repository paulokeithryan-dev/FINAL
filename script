-- Main Hunting Loop Hook
task.spawn(function()
    local lastPromptCheck, lastGardenClean, isProcessingHopLifecycle, lastPathCompute = 0, 0, false, 0
    local walkWaypoints, currentWPIndex = {}, 1
    
    while task.wait(0.1) do
        if Config.AutoRemoveOtherGardens and (os.clock() - lastGardenClean > 1.5) then
            lastGardenClean = os.clock()
            removeOtherGardensInstantly()
        end
        if Config.AutoReduceLag then applyAggressiveLagReduction() end
        
        if Config.PetHuntEnabled and not isProcessingHopLifecycle then
            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            local wildFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("WildPetSpawns")
            
            if rootPart and wildFolder and humanoid then
                local activeTarget = nil
                for _, petModel in ipairs(wildFolder:GetChildren()) do
                    local attr = petModel:GetAttribute("PetName")
                    if attr and (Config.TargetPets[attr] or Config.TargetPets[string.gsub(attr, "%s+", "")]) and petModel:FindFirstChild("RootPart") then
                        activeTarget = petModel
                        break
                    end
                end
                
                if activeTarget then
                    local petRoot = activeTarget.RootPart
                    local shovel = character:FindFirstChild("Shovel") or LocalPlayer.Backpack:FindFirstChild("Shovel")
                    if shovel and shovel.Parent == LocalPlayer.Backpack then humanoid:EquipTool(shovel) end
                    
                    while Config.PetHuntEnabled and activeTarget and activeTarget:IsDescendantOf(wildFolder) and petRoot do
                        local closestThief = nil
                        if Config.ProtectionEnabled then
                            for _, p in ipairs(Players:GetPlayers()) do
                                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                    if (p.Character.HumanoidRootPart.Position - petRoot.Position).Magnitude <= Config.ProtectionRadius then
                                        closestThief = p.Character.HumanoidRootPart break
                                    end
                                end
                            end
                        end
                        
                        if closestThief then
                            executeInterceptionManeuver(closestThief, petRoot)
                        else
                            if Config.TeleportMode == "Teleport" then
                                rootPart.CFrame = petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0)
                            elseif Config.TeleportMode == "Tween" then
                                if (rootPart.Position - (petRoot.Position + Vector3.new(0, Config.FlyHeight, 0))).Magnitude > 5 then
                                    smoothFlyTo(petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0), Config.TweenSpeed)
                                else
                                    rootPart.CFrame = petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0)
                                end
                            end
                        end
                        if os.clock() - lastPromptCheck > 0.05 then
                            lastPromptCheck = os.clock()
                            deployPurchaseInterception(activeTarget, rootPart)
                        end
                        task.wait()
                    end
                elseif Config.ServerHopEnabled then
                    isProcessingHopLifecycle = true
                    rotateServerInstance()
                    isProcessingHopLifecycle = false
                end
            end
        end
    end
end)

