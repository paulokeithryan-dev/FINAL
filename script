    if not PlayerGui then return end

    -- Safe Hook Interception to prevent breaks if native layers are sleeping
    local teleportButtonsGui = PlayerGui:WaitForChild("TeleportButtons", 8)
    if not teleportButtonsGui then return end
    
    local buttonContainer = teleportButtonsGui:WaitForChild("TeleportButtons", 5) or teleportButtonsGui:FindFirstChildOfClass("Frame")
    if not buttonContainer then return end
    
    local templateButton = buttonContainer:WaitForChild("SeedsButton", 5) or buttonContainer:FindFirstChildOfClass("ImageButton")
    if not templateButton then return end

    local teleports = workspace:WaitForChild("Teleports", 10)
    if not teleports then return end
    
    local gearsPart = teleports:WaitForChild("Gears", 5)
    local propsPart = teleports:WaitForChild("Props", 5)
    if not (gearsPart and propsPart) then return end

    local GEARS_COLOR = Color3.fromRGB(0, 162, 255)  
    local PROPS_COLOR = Color3.fromRGB(255, 138, 210) 

    local function teleportTo(targetPart)
        local character = LocalPlayer.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            character.HumanoidRootPart.CFrame = targetPart.CFrame + Vector3.new(0, 3, 0)
        end
    end

    local function cleanAndLockUI(button, labelText, themeColor)
        for _, child in ipairs(button:GetDescendants()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                child.Text = labelText
                child:GetPropertyChangedSignal("Text"):Connect(function()
                    child.Text = labelText
                end)
            end
            
            if child:IsA("ImageLabel") and child.Name ~= "Background" then
                if child.Size.X.Scale < 0.9 or string.find(string.lower(child.Name), "icon") or string.find(string.lower(child.Name), "leaf") then
                    child.Visible = false
                end
            end

            if child:IsA("ImageLabel") or child:IsA("ImageButton") then
                if child.Visible then
                    child.ImageColor3 = themeColor
                    child:GetPropertyChangedSignal("ImageColor3"):Connect(function()
                        child.ImageColor3 = themeColor
                    end)
                end
            elseif child:IsA("Frame") then
                child.BackgroundColor3 = themeColor
                child:GetPropertyChangedSignal("BackgroundColor3"):Connect(function()
                    child.BackgroundColor3 = themeColor
                end)
            end
        end

        button.BackgroundColor3 = themeColor
        if button:IsA("ImageButton") then
            button.ImageColor3 = themeColor
            button:GetPropertyChangedSignal("ImageColor3"):Connect(function()
                button.ImageColor3 = themeColor
            end)
        end
    end

    local function injectCustomButton(name, labelText, themeColor, targetPart)
        if buttonContainer:FindFirstChild(name) then
            buttonContainer[name]:Destroy()
        end

        local newButton = templateButton:Clone()
        newButton.Name = name

        cleanAndLockUI(newButton, labelText, themeColor)

        newButton.MouseButton1Click:Connect(function()
            teleportTo(targetPart)
        end)

        newButton.Parent = buttonContainer
    end

    injectCustomButton("GearsButton", "Gears", GEARS_COLOR, gearsPart)
    injectCustomButton("PropsButton", "Props", PROPS_COLOR, propsPart)
end)
