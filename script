--- Monitor weather changes by observing ReplicatedStorage / workspace
local function monitorWeather()
    local weatherFolder = ReplicatedStorage:FindFirstChild("Weather")
        or ReplicatedStorage:FindFirstChild("WeatherState")
        or Workspace:FindFirstChild("Weather")

    if weatherFolder then
        weatherFolder.ChildAdded:Connect(function(child)
            local name = child.Name
            for eventName, _ in pairs(WeatherEvents) do
                if string.find(name:lower(), eventName:lower()) then
                    WeatherState.Active = eventName
                    WeatherState.ActiveStartTime = os.time()
                    WeatherState.ActiveDuration = WeatherEvents[eventName].duration or 300
                    table.insert(WeatherState.History, {
                        event = eventName,
                        startTime = os.time(),
                    })
                    if Config.WeatherNotificationEnabled then
                        print(string.format("[WEATHER]: %s event has started! %s", eventName, WeatherEvents[eventName].desc))
                    end
                    break
                end
            end
        end)
    end
end

--- Calculate current price for auction lot using auctioneer decay math
local AuctioneerMath = {
    CurrentPrice = function(lot, now)
        if not lot or not lot.startPrice then return 0 end
        if lot.decrementIntervalSeconds <= 0 then return lot.startPrice end
        local elapsed = math.max(0, now - (lot.rolledAt or os.time()))
        local ticks = math.floor(elapsed / lot.decrementIntervalSeconds)
        local decAmt = math.round(lot.startPrice * (lot.decrementPercent or 0.5) / 100)
        return math.max(lot.minPrice or 0, lot.startPrice - (decAmt * ticks))
    end,

    TimeToMinPrice = function(lot)
        if not lot or lot.decrementIntervalSeconds <= 0 then return 0 end
        local totalTicks = math.ceil((lot.startPrice - (lot.minPrice or 0)) / (math.round(lot.startPrice * (lot.decrementPercent or 0.5) / 100)))
        return totalTicks * lot.decrementIntervalSeconds
    end,
}

