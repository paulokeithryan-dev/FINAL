local function smoothFlyTo(targetCFrame, speedOverride)
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local speed = speedOverride or Config.TweenSpeed
    local distance = (rootPart.Position - targetCFrame.Position).Magnitude
    local duration = distance / speed
    
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local flight = TweenService:Create(rootPart, tweenInfo, {CFrame = targetCFrame})
    flight:Play()
    flight.Completed:Wait()
end

local function executeDualActionStrike(shovel)
    local camera = workspace.CurrentCamera
    if camera then
        local safeX = 20
        local safeY = 220 
        VirtualInputManager:SendMouseButtonEvent(safeX, safeY, 0, true, game, 0)
        VirtualInputManager:SendMouseButtonEvent(safeX, safeY, 0, false, game, 0)
    end
    
    if shovel then
        shovel:Activate() 
        for _, obj in ipairs(shovel:GetDescendants()) do
            if obj:IsA("RemoteEvent") or obj:IsA("UnreliableRemoteEvent") then
                obj:FireServer() 
                obj:FireServer() 
            end
        end
    end
end

local function executeInterceptionManeuver(thiefRoot, petRoot)
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not rootPart or not humanoid then return end
    
    print("[TACTICAL]: Thief detected! Overriding velocity matrix to Max Combat Speed.")
    
    local shovel = character:FindFirstChild("Shovel") or LocalPlayer.Backpack:FindFirstChild("Shovel")
    if shovel and shovel.Parent == LocalPlayer.Backpack then
        humanoid:EquipTool(shovel)
        task.wait(0.02) 
    end
    
    local strikePosition = thiefRoot.CFrame * CFrame.new(0, 0, 1.2)
    smoothFlyTo(strikePosition, Config.CombatDashSpeed)
    
    if shovel then
        for i = 1, 10 do
            executeDualActionStrike(shovel)
            task.wait() 
        end
    end
    
    local returnPosition = petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0)
    smoothFlyTo(returnPosition, Config.CombatDashSpeed)
end

local function deployPurchaseInterception(activeTarget, rootPart)
    if not fireproximityprompt then return end
    
    if activeTarget then
        for _, obj in ipairs(activeTarget:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                fireproximityprompt(obj)
            end
        end
    end
    
    local gardens = workspace:FindFirstChild("Gardens")
    if gardens then
        for _, obj in ipairs(gardens:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                if obj:FindFirstAncestor("Signs") or string.find(obj.Name:lower(), "mailbox") or string.find(obj.Name:lower(), "sign") then
                    continue 
                end
                
                local parentPart = obj.Parent
                if parentPart and parentPart:IsA("BasePart") then
                    local distance = (parentPart.Position - rootPart.Position).Magnitude
                    if distance <= 20 then
                        fireproximityprompt(obj)
                    end
                end
            end
        end
    end
end

-- ---------------------------------------------------------------------
-- DEDICATED LOW-PLAYER PUBLIC SERVER FINDER ROTATION MATRIX
-- ---------------------------------------------------------------------
local function rotateServerInstance()
    print("[BOT_ENGINE]: Querying server directory for optimal low-player public instances...")
    local success, serverDirectory = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. tostring(game.PlaceId) .. "/servers/Public?sortOrder=Asc&limit=100"))
    end)
    
    if success and serverDirectory and serverDirectory.data then
        for _, server in ipairs(serverDirectory.data) do
            if server.id ~= game.JobId and tonumber(server.playing) <= tonumber(Config.MaxServerPlayers) then
                print(string.format("[BOT_ENGINE]: Targeted server match identified (%d players). Executing teleport sync...", server.playing))
                task.wait(0.5)
                
                local teleportSuccess, teleportErr = pcall(function()
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                end)
                if teleportSuccess then return end
            end
        end
    end
    
    print("[BOT_ENGINE]: Public query directory exhausted. Deploying baseline safety hop...")
    pcall(function()
        TeleportService:Teleport(game.PlaceId, LocalPlayer)
    end)
end

-- ---------------------------------------------------------------------
-- CONFIG LOAD / SAVE PERSISTENCE HANDLERS
-- ---------------------------------------------------------------------
local function saveConfig()
    local success, encoded = pcall(function()
        return HttpService:JSONEncode(Config)
    end)
    
    if success and writefile then
        writefile(FILE_NAME, encoded)
        print("[CONFIG]: Data safely written to local storage matrix.")
    else
        warn("[CONFIG]: Local execution hardware blocked data serialization write sequence.")
    end
end

local function loadConfig()
    if isfile and isfile(FILE_NAME) and readfile then
        local fileContents = readfile(FILE_NAME)
        local decodeSuccess, decodedTable = pcall(function()
            return HttpService:JSONDecode(fileContents)
        end)
        
        if decodeSuccess and type(decodedTable) == "table" then
            for key, value in pairs(decodedTable) do
                if type(value) == "table" and type(Config[key]) == "table" then
                    for subKey, subValue in pairs(value) do
                        Config[key][subKey] = subValue
                    end
                else
                    Config[key] = value
                end
            end
            
            local simpleElements = {
                "PetHuntEnabled", "ServerHopEnabled", "MaxServerPlayers", "ProtectionEnabled", 
                "AutoRemoveOtherGardens", "FullBright", "InfiniteZoom", "AntiFling", "LessKnockback", 
                "InstantPrompt", "BypassGameplayPaused", "ESPEnabled", "ESPSelectedPets", 
                "ESPSelectedRarities", "ESPSelectedSizes", "TeleportMode"
            }
            
            for _, key in ipairs(simpleElements) do
                if ToggleRegistry[key] then ToggleRegistry[key](Config[key]) end
            end
            
            for petName, isTargeted in pairs(Config.TargetPets) do
                if ToggleRegistry["Pet_" .. petName] then
                    ToggleRegistry["Pet_" .. petName](isTargeted)
                end
            end
            
            print("[CONFIG]: Setup configuration loaded and applied successfully.")
        end
    end
end

-- ---------------------------------------------------------------------
-- PERFORMANCE OPTIMIZATION UTILITIES
-- ---------------------------------------------------------------------
local function isMyGarden(garden)
    if garden.Name == LocalPlayer.Name or string.find(garden.Name, tostring(LocalPlayer.UserId)) then
        return true
    end
    if garden:GetAttribute("Owner") == LocalPlayer.Name or garden:GetAttribute("Owner") == LocalPlayer.UserId or garden:GetAttribute("OwnerID") == LocalPlayer.UserId then
        return true
    end
    for _, child in ipairs(garden:GetDescendants()) do
        if child:IsA("ValueBase") and (child.Value == LocalPlayer or child.Value == LocalPlayer.Name or tostring(child.Value) == tostring(LocalPlayer.UserId)) then
            return true
        end
        if child:IsA("TextLabel") and (string.find(child.Text, LocalPlayer.Name) or (LocalPlayer.DisplayName and string.find(child.Text, LocalPlayer.DisplayName))) then
            return true
        end
    end
    return false
end

local function removeOtherGardensInstantly()
    local gardensFolder = workspace:FindFirstChild("Gardens")
    if gardensFolder then
        for _, garden in ipairs(gardensFolder:GetChildren()) do
            if not isMyGarden(garden) then
                pcall(function() garden:Destroy() end)
            end
        end
    end
end

local function applyAggressiveLagReduction()
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.EnvironmentBlurIntensity = 0
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
    end)
    for _, obj in ipairs(Lighting:GetChildren()) do
        pcall(function()
            if obj:IsA("PostEffect") or obj:IsA("Atmosphere") or obj:IsA("Sky") or obj:IsA("Clouds") then
                obj:Destroy()
            end
        end)
    end
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        pcall(function()
            terrain.WaterWaterWaveSize = 0
            terrain.WaterWaveSpeed = 0
            terrain.WaterReflectance = 0
            terrain.WaterDetail = Enum.WaterDetail.Low
        end)
    end
    for _, instance in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if instance:IsA("ParticleEmitter") or instance:IsA("Smoke") or instance:IsA("Sparkles") or instance:IsA("Fire") then
                instance.Enabled = false
                instance:Destroy()
            elseif instance:IsA("Decal") or instance:IsA("Texture") or instance:IsA("SurfaceAppearance") or instance:IsA("MaterialVariant") then
                instance:Destroy()
            elseif instance:IsA("BasePart") then
                instance.CastShadow = false
                instance.Material = Enum.Material.SmoothPlastic
                instance.Reflectance = 0
                if instance:IsA("MeshPart") then
                    pcall(function() instance.RenderFidelity = Enum.RenderFidelity.Performance end)
                end
            end
        end)
    end
    pcall(function() settings().Physics.PhysicsEnvironmentalThrottle = Enum.EnviromentalThrottle.Enabled end)
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
end

-- ---------------------------------------------------------------------
-- HIGH-PERFORMANCE ESP RENDERING ENGINE MATRIX
-- ---------------------------------------------------------------------
local ActiveESP = {}

local function clearAllESP()
    for model, elements in pairs(ActiveESP) do
        for _, obj in ipairs(elements) do pcall(function() obj:Destroy() end) end
    end
    table.clear(ActiveESP)
end

local function renderESPForModel(petModel)
    if not Config.ESPEnabled then return end
    if not petModel:FindFirstChild("RootPart") then return end
    if ActiveESP[petModel] then return end
    
    local petName = petModel:GetAttribute("PetName") or petModel.Name
    local cleanName = string.gsub(petName, "%s+", "")
    
    if Config.ESPSelectedPets and Config.ESPSelectedPets ~= "" and Config.ESPSelectedPets ~= "None" and Config.ESPSelectedPets ~= "Select Options" then
        local foundMatch = false
        for token in string.gmatch(Config.ESPSelectedPets, "[^,%s]+") do
            if string.lower(cleanName) == string.lower(token) or string.lower(petName) == string.lower(token) then
                foundMatch = true
                break
            end
        end
        if not foundMatch then return end
    end
    
    local petRarity = "Unknown"
    for _, item in ipairs(Database) do
        local targetKey = item[2]
        if not item[3] then targetKey = item[1] end
        if string.gsub(targetKey, "%s+", "") == cleanName then
            petRarity = string.match(item[2] or item[3] or "", "^%a+") or "Unknown"
            break
        end
    end
    
    if Config.ESPSelectedRarities and Config.ESPSelectedRarities ~= "" and Config.ESPSelectedRarities ~= "None" and Config.ESPSelectedRarities ~= "Select Options" then
        local foundMatch = false
        for token in string.gmatch(Config.ESPSelectedRarities, "[^,%s]+") do
            if string.lower(petRarity) == string.lower(token) then
                foundMatch = true
                break
            end
        end
        if not foundMatch then return end
    end
    
    local rawSize = petModel:GetAttribute("PetSize") or petModel:GetAttribute("Size") or "Normal"
    if Config.ESPSelectedSizes and Config.ESPSelectedSizes ~= "" and Config.ESPSelectedSizes ~= "None" and Config.ESPSelectedSizes ~= "Select Options" then
        local foundMatch = false
        for token in string.gmatch(Config.ESPSelectedSizes, "[^,%s]+") do
            if string.lower(tostring(rawSize)) == string.lower(token) then
                foundMatch = true
                break
            end
        end
        if not foundMatch then return end
    end
    
    local chosenHex = RarityHexColors[petRarity] or "#FFFFFF"
    local trackedElements = {}
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 160, 0, 30)
    billboard.AlwaysOnTop = true
    billboard.Adornee = petModel.RootPart
    billboard.Parent = petModel.RootPart
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.RichText = true
    textLabel.Text = string.format("<font color=\"#FFFFFF\">%s</font> <font color=\"%s\">[%s]</font>", petName, chosenHex, petRarity)
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 12
    textLabel.TextStrokeTransparency = 0.4
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.Parent = billboard
    table.insert(trackedElements, billboard)
    
    ActiveESP[petModel] = trackedElements
end

