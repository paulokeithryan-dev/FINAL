local ActiveESP = {}

local function clearAllESP()
    for model, elements in pairs(ActiveESP) do
        for _, obj in ipairs(elements) do pcall(function() obj:Destroy() end) end
    end
    table.clear(ActiveESP)
end

local function renderESPForModel(petModel)
    if not Config.ESPEnabled or not petModel:FindFirstChild("RootPart") or ActiveESP[petModel] then return end
    local petName = petModel:GetAttribute("PetName") or petModel.Name
    local cleanName = string.gsub(petName, "%s+", "")
    
    if Config.ESPSelectedPets and Config.ESPSelectedPets ~= "Select Options" and Config.ESPSelectedPets ~= "None" then
        local found = false
        for token in string.gmatch(Config.ESPSelectedPets, "[^,%s]+") do
            if string.lower(cleanName) == string.lower(token) then found = true break end
        end
        if not found then return end
    end
    
    local petRarity = "Unknown"
    for _, item in ipairs(Database) do
        local key = item[3] and item[2] or item[1]
        if string.gsub(key, "%s+", "") == cleanName then
            petRarity = string.match(item[2] or item[3] or "", "^%a+") or "Unknown"
            break
        end
    end
    
    local chosenHex = RarityHexColors[petRarity] or "#FFFFFF"
    local tracked = {}
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 160, 0, 30)
    billboard.AlwaysOnTop = true
    billboard.Adornee = petModel.RootPart
    billboard.Parent = petModel.RootPart
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.RichText = true
    textLabel.Text = string.format("<font color=\"#FFFFFF\">%s</font> <font color=\"%s\">[%s]</font>", petName, chosenHex, petRarity)
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 12
    textLabel.TextStrokeTransparency = 0.4
    textLabel.Parent = billboard
    
    table.insert(tracked, billboard)
    ActiveESP[petModel] = tracked
end

