    harvest = 1.5,        -- Medium: fruit checking
    weather = 2.0,        -- Medium: weather monitoring
    esp = 0.5,            -- Fast: ESP updates
    steal = 0.3,          -- Fast: theft detection
    guild = 30,           -- Slow: guild updates
    skills = 10,          -- Medium: skill points
    economy = 10,         -- Medium: daily deals
