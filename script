    local function renderPetESP(petModel)
        if not Config.ESPEnabled then return end

        local petName = petModel:GetAttribute("PetName") or petModel.Name
        local cleanName = string.gsub(string.lower(petName), "%s+", "")

        if next(ESPCache.Pets) then
            local matched = false
            for _, pd in ipairs(PetDatabase) do
                local dbKey = string.lower(string.gsub(pd[2], "%s+", ""))
                local dbName = string.lower(string.gsub(pd[1], "%s+", ""))
                if (cleanName == dbKey or cleanName == dbName) and (ESPCache.Pets[dbKey] or ESPCache.Pets[dbName]) then
                    matched = true; break
                end
            end
            if not matched then return end
        end

        local petRarity = "Unknown"
        for _, item in ipairs(PetDatabase) do
            if string.gsub(item[2], "%s+", "") == cleanName then
                petRarity = item[3] or "Unknown"; break
            end
        end

        if next(ESPCache.Rarities) and not ESPCache.Rarities[string.lower(petRarity)] then return end

        local rawSize = tostring(petModel:GetAttribute("PetSize") or petModel:GetAttribute("Size") or "Normal")
        if next(ESPCache.Sizes) and not ESPCache.Sizes[string.lower(rawSize)] then return end

        local hex = RarityHexColors[petRarity] or "#FFFFFF"
        local label = string.format('<font color="%s">%s</font> <font color="%s">[%s]</font>', "#FFFFFF", petName, hex, petRarity)
        renderESP(petModel, label, hex)
    end

