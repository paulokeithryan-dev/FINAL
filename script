local function renderPetESP(petModel)
    if not Config.ESPEnabled then return end

    local petName = petModel:GetAttribute("PetName") or petModel.Name
    local cleanName = string.gsub(string.lower(petName), "%s+", "")

    -- Check pet filter
    if next(ESPCache.Pets) then
        local matched = false
        for _, petData in ipairs(PetDatabase) do
            local dbName = string.lower(string.gsub(petData[1], "%s+", ""))
            local dbKey = string.lower(string.gsub(petData[2], "%s+", ""))
            if cleanName == dbName or cleanName == dbKey then
                if ESPCache.Pets[dbName] or ESPCache.Pets[dbKey] then
                    matched = true
                    break
                end
            end
        end
        if not matched then return end
    end

    -- Determine rarity
    local petRarity = "Unknown"
    for _, item in ipairs(PetDatabase) do
        local targetKey = item[2]
        if string.gsub(targetKey, "%s+", "") == cleanName then
            petRarity = item[3] or "Unknown"
            break
        end
    end

    -- Check rarity filter
    if next(ESPCache.Rarities) and not ESPCache.Rarities[string.lower(petRarity)] then
        return
    end

    -- Check size filter
    local rawSize = tostring(petModel:GetAttribute("PetSize") or petModel:GetAttribute("Size") or "Normal")
    if next(ESPCache.Sizes) and not ESPCache.Sizes[string.lower(rawSize)] then
        return
    end

    local hex = RarityHexColors[petRarity] or "#FFFFFF"
    local label = string.format('<font color="%s">%s</font> <font color="%s">[%s]</font>',
        "#FFFFFF", petName, hex, petRarity)

    renderESPForModel(petModel, label, hex)
end

local function renderFruitESP(fruitModel)
    if not Config.ESPEnabled or not Config.ESPShowFruit then return end

    local fruitName = fruitModel:GetAttribute("FruitName") or fruitModel.Name
    local fruitRarity = fruitModel:GetAttribute("Rarity") or fruitModel:GetAttribute("FruitRarity") or "Common"

    if Config.ESPShowRareFruitOnly then
        local rarityValue = FruitValueByRarity[fruitRarity] or 0
        if rarityValue < 500 then return end
    end

    if next(ESPCache.Fruit) then
        if not ESPCache.Fruit[string.lower(fruitRarity)] then return end
    end

    local hex = RarityHexColors[fruitRarity] or "#FFFFFF"
    local label = string.format('<font color="%s">%s</font> <font color="%s">[%s]</font>',
        "#FFFFFF", fruitName, hex, fruitRarity)

    renderESPForModel(fruitModel, label, hex, {140, 24, 10})
end
