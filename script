-- 3. EVENT-BASED PERFORMANCE ANTI-FLING ENGINE
--===================================================================================--

local function shieldCharacterPhysics(character)
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanTouch = false -- Mitigates cross-simulation velocity collisions
            
            -- Prevent root part velocity spikes
            if part.Name == "HumanoidRootPart" then
                part:GetPropertyChangedSignal("Velocity"):Connect(function()
                    if part.Velocity.Magnitude > 75 then
                        part.Velocity = Vector3.new(0, 0, 0)
                        part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    end
                end)
            end
        end
    end
end

local function initializeAntiFlingEngine()
    if not Config.Automation.AntiFling then return end

    -- Hook completely driven by character life cycles
    local function processPlayer(player)
        if player == LocalPlayer then return end
        player.CharacterAdded:Connect(function(char)
            char:WaitForChild("HumanoidRootPart", 5)
            shieldCharacterPhysics(char)
        end)
        if player.Character then
            shieldCharacterPhysics(player.Character)
        end
    end

    Players.PlayerAdded:Connect(processPlayer)
    for _, player in ipairs(Players:GetPlayers()) do
        processPlayer(player)
    end
end

--===================================================================================--
-- 4. SMART PATHFINDING & ESCAPE VECTOR GUARD
--===================================================================================--

local function calculateEscapeVector(humanoidRootPart)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}

    -- Circular scan pattern to discover geometric exits
    for i = 1, 8 do
        local angle = math.rad(i * 45)
        local direction = Vector3.new(math.cos(angle), 0, math.sin(angle)) * 6
        local origin = humanoidRootPart.Position + Vector3.new(0, 1, 0)
        
        local raycastResult = Workspace:Raycast(origin, direction, raycastParams)
        if not raycastResult then
            -- Found open pathway trajectory direction vector
            return direction.Unit * 8
        end
    end
    return Vector3.new(0, 10, 0) -- Vertical fallback default jump vector
end

local function navigateSmartPath(destination)
    if not Config.Automation.PathfindingFarm then return end
    
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local hrp = character:WaitForChild("HumanoidRootPart")
    
    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true
    })
    
    local success, errorMessage = pcall(function()
        path:ComputeAsync(hrp.Position, destination)
    end)
    
    if success and path.Status == Enum.PathStatus.Success then
        local waypoints = path:GetWaypoints()
        
        for idx, waypoint in ipairs(waypoints) do
            humanoid:MoveTo(waypoint.Position)
            
            -- Predictive Raycast Obstruction Evaluation
            local initialTime = os.clock()
            while (hrp.Position - waypoint.Position).Magnitude > 3 do
                task.wait()
                
                -- Check for physical stall state conditions
                if os.clock() - initialTime > 1.2 and hrp.Velocity.Magnitude < 1 then
                    warn("[Premium Engine] Stalled! Executing Raycast Escape Vector...")
                    
                    local escapeVector = calculateEscapeVector(hrp)
                    if escapeVector.Y > 5 then
                        humanoid.Jump = true
                    else
                        hrp.CFrame = hrp.CFrame + escapeVector
                    end
                    task.wait(0.2)
                    break
                end
            end
            
            if waypoint.Action == Enum.PathWaypointAction.Jump then
                humanoid.Jump = true
            end
        end
    end
end

