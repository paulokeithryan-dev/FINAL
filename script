local AuctioneerState = {
    Snapshots = {},
    LastCheck = 0,
    CheckInterval = 5,
    TargetLotId = nil,
    TargetPrice = 0,
}

local function runAuctionSniper()
    if not Config.AuctionSniperEnabled then return end

    local now = os.time()
    if now - AuctioneerState.LastCheck < AuctioneerState.CheckInterval then return end
    AuctioneerState.LastCheck = now

    local snapshot = fetchAuctionSnapshot()
    if not snapshot then return end

    AuctioneerState.Snapshots = snapshot

    for _, lot in ipairs(snapshot) do
        local lotName = string.lower(lot.itemName or lot.name or "")
        local targetName = string.lower(Config.AuctionTargetItem or "")

        if string.find(lotName, targetName) then
            -- Check rarity match
            local lotRarity = string.lower(lot.rarity or lot.itemRarity or "")
            local targetRarity = string.lower(Config.AuctionAutoRarity or "")
            if targetRarity ~= "None" and targetRarity ~= "" and lotRarity ~= targetRarity then
                continue
            end

            local currentPrice = AuctioneerMath.CurrentPrice(lot, now)
            local maxPrice = Config.AuctionMaxPrice or 1000000

            if currentPrice <= maxPrice then
                -- Buy immediately!
                attemptAuctionPurchase(lot.id or lot.lotId, currentPrice)
                print(string.format("[SNIPER]: PURCHASED %s (%s) for %s at %s!", lotName, lotRarity, currentPrice, os.date("%H:%M:%S")))
                return
            end
        end
    end
end

local function attemptAuctionPurchase(lotId, price)
    FirePacket(Packets.AuctioneerPurchaseLot.id, tostring(lotId), tonumber(price) or 0)
    print(string.format("[SNIPER]: Firing purchase for Lot %s at %s", tostring(lotId), tostring(price)))
end

