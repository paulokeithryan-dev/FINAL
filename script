    -- =====================================================================
    -- SECTION 4: HIGH-FIDELITY PACKET NETWORKING ENGINE
    -- =====================================================================
    -- This module mimics the structure defined in Compiled.lua (packet.txt & networking.txt)
    -- It provides a resilient, fallback-capable method to find and fire game remotes.

    local NetworkEngine = {
        ResolvedRemote = nil,
        RouteFound = false,
        FallbackPaths = {
            "Network", "Remote", "Packets", "Remotes", "API"
        }
    }

    function NetworkEngine:LocateCommunicationChannel()
        if self.RouteFound and self.ResolvedRemote then return self.ResolvedRemote end

        -- 1. Check known fallback paths in ReplicatedStorage
        for _, path in ipairs(self.FallbackPaths) do
            local target = ReplicatedStorage:FindFirstChild(path)
            if target and (target:IsA("RemoteEvent") or target:IsA("RemoteFunction") or target:IsA("Folder")) then
                -- If it's a folder, look for an event inside
                if target:IsA("Folder") then
                    for _, child in ipairs(target:GetChildren()) do
                        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                            self.ResolvedRemote = child
                            self.RouteFound = true
                            return child
                        end
                    end
                else
                    self.ResolvedRemote = target
                    self.RouteFound = true
                    return target
                end
            end
        end

        -- 2. Deep scan ReplicatedStorage for 'packet' or 'remote' named events
        for _, descendant in ipairs(ReplicatedStorage:GetDescendants()) do
            if descendant:IsA("RemoteEvent") or descendant:IsA("RemoteFunction") then
                local name = string.lower(descendant.Name)
                if string.find(name, "packet") or string.find(name, "network") then
                    self.ResolvedRemote = descendant
                    self.RouteFound = true
                    return descendant
                end
            end
        end

        LogDebug("Network channel resolution failed. Actions requiring server communication may drop.")
        return nil
    end

    function NetworkEngine:Fire(headerName, ...)
        local channel = self:LocateCommunicationChannel()
        if not channel then return false, "Channel Unresolved" end

        local success, result = pcall(function(...)
            if channel:IsA("RemoteFunction") then
                return channel:InvokeServer(headerName, ...)
            elseif channel:IsA("RemoteEvent") then
                channel:FireServer(headerName, ...)
                return true
            end
        end, ...)

        if not success then
            LogDebug("Packet Transmission Failed: [" .. tostring(headerName) .. "] - " .. tostring(result))
        end

        return success, result
    end

    -- Specialized wrapper for Shop purchases
    function NetworkEngine:PurchaseItem(itemType, itemName, amount)
        amount = amount or 1
        -- Based on compiled.lua packet structures:
        -- e.g., v1("SeedShopPurchase", v1.String, v1.Number)
        -- e.g., v1("GearShopPurchase", v1.String)
        
        local success = false
        if itemType == "Seed" then
            success = self:Fire("SeedShopPurchase", itemName, amount)
            if not success then success = self:Fire("BuySeed", itemName, amount) end
            if not success then success = self:Fire("PurchaseItem", "Seeds", itemName, amount) end
        elseif itemType == "Gear" then
            success = self:Fire("GearShopPurchase", itemName)
            if not success then success = self:Fire("BuyGear", itemName) end
            if not success then success = self:Fire("PurchaseItem", "Gears", itemName, 1) end
        elseif itemType == "Egg" then
            success = self:Fire("EggShopPurchase", itemName)
            if not success then success = self:Fire("BuyEgg", itemName) end
        elseif itemType == "Crate" then
            success = self:Fire("CrateShopPurchase", itemName)
        else
            -- Generic fallback
            success = self:Fire("BuyItem", itemName, amount)
            if not success then success = self:Fire("Purchase", itemName, amount) end
        end

        return success
    end

