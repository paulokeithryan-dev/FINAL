    end

    function EspEngine:RenderLoop()
        if not Config.ESPEnabled then
            self:ClearVisuals()
            return
        end

        self:InitContainer()

        -- Cleanup Invalid/Destroyed Targets
        for target, visual in pairs(EngineState.VisualElementsESP) do
            if not target or not target.Parent or not target:IsDescendantOf(Workspace) then
                if visual.Billboard then pcall(function() visual.Billboard:Destroy() end) end
                if visual.Highlight then pcall(function() visual.Highlight:Destroy() end) end
                EngineState.VisualElementsESP[target] = nil
            end
        end

        -- Render Wild Pets
        local petContainers = {Workspace:FindFirstChild("WildPets"), Workspace:FindFirstChild("Pets")}
        for _, container in ipairs(petContainers) do
            if container then
                for _, pet in ipairs(container:GetChildren()) do
                    if pet:IsA("Model") and not EngineState.VisualElementsESP[pet] then
                        local isWild = pet:GetAttribute("Wild") or string.find(string.lower(pet.Name), "wild") or container.Name == "WildPets"
                        if isWild then
                            local petName = pet:GetAttribute("PetName") or pet.Name
                            local nameLower = string.lower(string.gsub(petName, "%s+", ""))
                            
                            local allowRender = FilterESP.Pets["*"] or FilterESP.Pets[nameLower]
                            
                            if allowRender then
                                local rarity = "Unknown"
                                for _, dbPet in ipairs(Database.Pets) do
                                    if string.lower(string.gsub(dbPet[2], "%s+", "")) == nameLower then
                                        rarity = dbPet[3]
                                        break
                                    end
                                end
                                
                                local hex = Database.RarityColors[rarity] or "#FFFFFF"
                                local txt = string.format('<font color="%s">%s</font> <font color="%s">[%s]</font>', "#FFFFFF", petName, hex, rarity)
                                self:CreateVisual(pet, txt, Color3.fromHex(string.gsub(hex, "#", "")))
                            end
                        end
                    end
                end
            end
        end

        -- Render Fruits/Crops
        if Config.ESPShowFruit then
            local tycoon = AutomationCore:GetPlayerTycoon()
            if tycoon then
                local _, plants = AutomationCore:GetPlantsAndPlots(tycoon)
                for _, plant in ipairs(plants) do
                    if not EngineState.VisualElementsESP[plant] then
                        local rarity = plant:GetAttribute("Rarity") or plant:GetAttribute("FruitRarity") or "Common"
                        local isRare = rarity ~= "Common"
                        
                        if not Config.ESPShowRareFruitOnly or isRare then
                            local hex = Database.RarityColors[rarity] or "#00FF00"
                            local txt = string.format('<font color="%s">%s</font> <font color="%s">[%s]</font>', "#FFFFFF", plant.Name, hex, rarity)
                            self:CreateVisual(plant, txt, Color3.fromHex(string.gsub(hex, "#", "")))
                        end
                    end
                end
            end
        end
    end

