--- Get nearest player who might be a thief (near your garden, no HumanoidRootPart collision)
local function getNearestThief()
    local rootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end

    local nearest = nil
    local nearestDist = math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local theirRoot = player.Character:FindFirstChild("HumanoidRootPart")
            if theirRoot then
                local dist = (theirRoot.Position - rootPart.Position).Magnitude
                if dist < nearestDist and dist < Config.ProtectionRadius then
                    nearest = player
                    nearestDist = dist
                end
            end
        end
    end

    return nearest
end

