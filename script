-- ---------------------------------------------------------------------
-- MAIN RUNTIME CORE AUTOMATION LIFECYCLE (farm loop & hop)
-- ---------------------------------------------------------------------
task.spawn(function()
    local lastPromptCheck = 0
    local lastGardenClean = 0
    local isProcessingHopLifecycle = false
    
    while task.wait(0.1) do
        if Config.AutoRemoveOtherGardens and (os.clock() - lastGardenClean > 1.5) then
            lastGardenClean = os.clock()
            removeOtherGardensInstantly()
        end
        
        if Config.PetHuntEnabled then
            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            local mapFolder = workspace:FindFirstChild("Map")
            local wildFolder = mapFolder and mapFolder:FindFirstChild("WildPetSpawns")
            
            if rootPart and wildFolder and humanoid then
                
                -- INTERCEPTION OPTION A: SERVER-HOP MODALITY ENABLED
                if Config.ServerHopEnabled then
                    if not isProcessingHopLifecycle then
                        isProcessingHopLifecycle = true
                        print("[BOT_ENGINE]: Server Hop Routine Initiated. Running synchronization streaming checks...")
                        
                        local targetPet = nil
                        local scanAttempts = 6
                        
                        for attempt = 1, scanAttempts do
                            if not Config.PetHuntEnabled or not Config.ServerHopEnabled then break end
                            print(string.format("[BOT_ENGINE]: Scanning map boundaries (%d/%d)...", attempt, scanAttempts))
                            
                            for _, petModel in ipairs(wildFolder:GetChildren()) do
                                local attributeName = petModel:GetAttribute("PetName")
                                if attributeName then
                                    local internalKey = string.gsub(attributeName, "%s+", "")
                                    if (Config.TargetPets[attributeName] or Config.TargetPets[internalKey]) and petModel:FindFirstChild("RootPart") then
                                        targetPet = petModel
                                        break
                                    end
                                end
                            end
                            if targetPet then break end
                            task.wait(0.5)
                        end
                        
                        if targetPet and Config.PetHuntEnabled and Config.ServerHopEnabled then
                            local petRoot = targetPet.RootPart
                            local petName = targetPet:GetAttribute("PetName") or targetPet.Name
                            print("[BOT_ENGINE]: Target signature captured! Locking execution bounds onto: " .. tostring(petName))
                            
                            local shovel = character:FindFirstChild("Shovel") or LocalPlayer.Backpack:FindFirstChild("Shovel")
                            if shovel and shovel.Parent == LocalPlayer.Backpack then
                                humanoid:EquipTool(shovel)
                                task.wait(0.1)
                            end
                            
                            while Config.PetHuntEnabled and Config.ServerHopEnabled and targetPet and targetPet:IsDescendantOf(wildFolder) and petRoot do
                                local closestThief = nil
                                if Config.ProtectionEnabled then
                                    for _, player in ipairs(Players:GetPlayers()) do
                                        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                                            local playerRoot = player.Character.HumanoidRootPart
                                            local distanceToPet = (playerRoot.Position - petRoot.Position).Magnitude
                                            if distanceToPet <= Config.ProtectionRadius then
                                                closestThief = playerRoot
                                                break
                                            end
                                        end
                                    end
                                end
                                
                                if closestThief then
                                    executeInterceptionManeuver(closestThief, petRoot)
                                else
                                    if Config.TeleportMode == "Teleport" then
                                        rootPart.CFrame = petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0)
                                    elseif Config.TeleportMode == "Tween" then
                                        local dist = (rootPart.Position - (petRoot.Position + Vector3.new(0, Config.FlyHeight, 0))).Magnitude
                                        if dist > 5 then
                                            smoothFlyTo(petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0), Config.TweenSpeed)
                                        else
                                            rootPart.CFrame = petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0)
                                        end
                                    elseif Config.TeleportMode == "Walk" then
                                        humanoid:MoveTo(petRoot.Position)
                                    end
                                    if shovel and shovel.Parent == LocalPlayer.Backpack then humanoid:EquipTool(shovel) end
                                end
                                
                                if os.clock() - lastPromptCheck > 0.05 then
                                    lastPromptCheck = os.clock()
                                    deployPurchaseInterception(targetPet, rootPart)
                                end
                                task.wait()
                            end
                            
                            print("[BOT_ENGINE]: Capture signature successful! Enforcing 40-second static cooldown before initiating rotation...")
                            task.wait(40)
                        else
                            print("[BOT_ENGINE]: Zero target signatures detected across map boundaries during this session cycle.")
                        end
                        
                        if Config.PetHuntEnabled and Config.ServerHopEnabled then
                            rotateServerInstance()
                        end
                        isProcessingHopLifecycle = false
                    end
                    
                else
                    -- INTERCEPTION OPTION B: CONTINUOUS INFINITE ROOM STAY FARMING
                    local activeTarget = nil
                    for _, petModel in ipairs(wildFolder:GetChildren()) do
                        local attributeName = petModel:GetAttribute("PetName")
                        if attributeName then
                            local internalKey = string.gsub(attributeName, "%s+", "")
                            if (Config.TargetPets[attributeName] or Config.TargetPets[internalKey]) and petModel:FindFirstChild("RootPart") then
                                activeTarget = petModel
                                break
                            end
                        end
                    end
                    
                    if activeTarget then
                        local petRoot = activeTarget.RootPart
                        local petName = activeTarget:GetAttribute("PetName") or activeTarget.Name
                        print("[HUNTER]: Safe navigation tracking locked onto " .. tostring(petName))
                        
                        local shovel = character:FindFirstChild("Shovel") or LocalPlayer.Backpack:FindFirstChild("Shovel")
                        if shovel and shovel.Parent == LocalPlayer.Backpack then
                            humanoid:EquipTool(shovel)
                            task.wait(0.1)
                        end
                        
                        while Config.PetHuntEnabled and not Config.ServerHopEnabled and activeTarget and activeTarget:IsDescendantOf(wildFolder) and petRoot do
                            local closestThief = nil
                            if Config.ProtectionEnabled then
                                for _, player in ipairs(Players:GetPlayers()) do
                                    if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                                        local playerRoot = player.Character.HumanoidRootPart
                                        local distanceToPet = (playerRoot.Position - petRoot.Position).Magnitude
                                        if distanceToPet <= Config.ProtectionRadius then
                                            closestThief = playerRoot
                                            break
                                        end
                                    end
                                end
                            end
                            
                            if closestThief then
                                executeInterceptionManeuver(closestThief, petRoot)
                            else
                                if Config.TeleportMode == "Teleport" then
                                    rootPart.CFrame = petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0)
                                elseif Config.TeleportMode == "Tween" then
                                    local dist = (rootPart.Position - (petRoot.Position + Vector3.new(0, Config.FlyHeight, 0))).Magnitude
                                    if dist > 5 then
                                        smoothFlyTo(petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0), Config.TweenSpeed)
                                    else
                                        rootPart.CFrame = petRoot.CFrame * CFrame.new(0, Config.FlyHeight, 0)
                                    end
                                elseif Config.TeleportMode == "Walk" then
                                    humanoid:MoveTo(petRoot.Position)
                                end
                                if shovel and shovel.Parent == LocalPlayer.Backpack then humanoid:EquipTool(shovel) end
                            end
                            
                            if os.clock() - lastPromptCheck > 0.05 then
                                lastPromptCheck = os.clock()
                                deployPurchaseInterception(activeTarget, rootPart)
                            end
                            task.wait()
                        end
                        deployPurchaseInterception(nil, rootPart)
                        print("[HUNTER]: Target tracking concluded.")
                    end
                end
                
            end
        end
    end
end)

