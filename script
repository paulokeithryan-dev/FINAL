    local AuctioneerMath = {
        CurrentPrice = function(lot, now)
            if not lot or not lot.startPrice then return 0 end
            local interval = lot.decrementIntervalSeconds or 0
            if interval <= 0 then return lot.startPrice end
            local elapsed = math.max(0, now - (lot.rolledAt or os.time()))
            local ticks = math.floor(elapsed / interval)
            local pct = lot.decrementPercent or 0.5
            local decAmt = math.round(lot.startPrice * pct / 100)
            return math.max(lot.minPrice or 0, lot.startPrice - (decAmt * ticks))
        end,
        TimeToMinPrice = function(lot)
            if not lot then return 0 end
            local interval = lot.decrementIntervalSeconds or 0
            if interval <= 0 then return 0 end
            local pct = lot.decrementPercent or 0.5
            local decAmt = math.round(lot.startPrice * pct / 100)
            if decAmt <= 0 then return 0 end
            local totalTicks = math.ceil((lot.startPrice - (lot.minPrice or 0)) / decAmt)
            return totalTicks * interval
        end,
    }

