-- High Performance ESP Cache Lookup Tables
local ESPCache = { Pets = {}, Rarities = {}, Sizes = {} }
local AuctionCache = { Seeds = {}, Gear = {}, Packs = {}, Eggs = {} }
local function updateAuctionCache(cacheType, commaStr)
    AuctionCache[cacheType] = {}
    if commaStr and commaStr ~= "None" and commaStr ~= "Select Options" and commaStr ~= "" then
            for token in string.gmatch(commaStr, "[^,]+") do
                local cleanToken = string.lower(string.gsub(token, "[%s%p]+", ""))
                if cleanToken ~= "" then
                    AuctionCache[cacheType][cleanToken] = true
                end
            end
    end
end
local function updateESPCache(cacheType, commaStr)
    ESPCache[cacheType] = {}
    if commaStr and commaStr ~= "None" and commaStr ~= "Select Options" and commaStr ~= "" then
        for token in string.gmatch(commaStr, "[^,]+") do
            local cleanToken = string.lower(string.gsub(token, "[%s%p]+", ""))
            if cleanToken ~= "" then
                ESPCache[cacheType][cleanToken] = true
            end
        end
    end
end

