local ActiveESP = {}

local function clearAllESP()
    for model, elements in pairs(ActiveESP) do
        for _, obj in ipairs(elements) do
            pcall(function() obj:Destroy() end)
        end
    end
    table.clear(ActiveESP)
end

local function renderESPForModel(petModel)
    if not Config.ESPEnabled then return end
    if not petModel:FindFirstChild("RootPart") then return end
    if ActiveESP[petModel] then return end
    
    local petName = petModel:GetAttribute("PetName") or petModel.Name
    local cleanName = string.gsub(petName, "%s+", "")
    
    -- Optimized Filter 1: Species Dictionary Match
    if next(ESPCache.Pets) then
        if not ESPCache.Pets[string.lower(cleanName)] and not ESPCache.Pets[string.lower(string.gsub(petName, "%s+", ""))] then 
            return 
        end
    end
    
    -- Filter 2: Rarity Extraction Lookup
    local petRarity = "Unknown"
    for _, item in ipairs(Database) do
        local targetKey = item[2]
        if not item[3] then targetKey = item[1] end
        if string.gsub(targetKey, "%s+", "") == cleanName then
            petRarity = string.match(item[2] or item[3] or "", "^%a+") or "Unknown"
            break
        end
    end
    
    -- Optimized Filter 2 Check
    if next(ESPCache.Rarities) then
        if not ESPCache.Rarities[string.lower(petRarity)] then 
            return 
        end
    end
    
    -- Optimized Filter 3 Check
    local rawSize = petModel:GetAttribute("PetSize") or petModel:GetAttribute("Size") or "Normal"
    if next(ESPCache.Sizes) then
        if not ESPCache.Sizes[string.lower(tostring(rawSize))] then 
            return 
        end
    end
    
    -- Dynamic Text Color Coding Sequence
    local chosenHex = RarityHexColors[petRarity] or "#FFFFFF"
    
    local trackedElements = {}
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 160, 0, 30)
    billboard.AlwaysOnTop = true
    billboard.Adornee = petModel.RootPart
    billboard.Parent = petModel.RootPart
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.RichText = true
    
    -- Combines White Pet name with customizable Rarity-colored text block
    textLabel.Text = string.format("<font color=\"%s\">%s</font> <font color=\"%s\">[%s]</font>", "#FFFFFF", petName, chosenHex, petRarity)
    
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 12
    textLabel.TextStrokeTransparency = 0.4
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.Parent = billboard
    table.insert(trackedElements, billboard)
    
    ActiveESP[petModel] = trackedElements
end

