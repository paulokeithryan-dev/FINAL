    function AutomationCore:RunPetAndWildRoutine()
        if Config.AutoOpenEggs then
            NetworkEngine:Fire("OpenEgg", Config.TargetEggForAutoBuy)
            NetworkEngine:Fire("EggOpen", Config.TargetEggForAutoBuy)
        end

        if Config.AutoEquipBestPet then
            NetworkEngine:Fire("PetRequestEquipByName", "Best")
            NetworkEngine:Fire("EquipBestPets")
        end

        if Config.WildPetAutoTame then
            local wildContainers = {
                Workspace:FindFirstChild("WildPets"),
                Workspace:FindFirstChild("WildPetSpawns"),
                Workspace:FindFirstChild("Pets")
            }

            for _, container in ipairs(wildContainers) do
                if container then
                    for _, entity in ipairs(container:GetChildren()) do
                        local isWild = entity:GetAttribute("Wild") or entity:GetAttribute("IsWild") or string.find(string.lower(entity.Name), "wild")
                        if isWild and entity:IsA("Model") and entity:FindFirstChildWhichIsA("BasePart") then
                            local char = LocalPlayer.Character
                            if char and char:FindFirstChild("HumanoidRootPart") then
                                local hrp = char.HumanoidRootPart
                                local originalCFrame = hrp.CFrame
                                
                                -- Move to pet
                                hrp.CFrame = entity:GetPivot() + Vector3.new(0, Config.FlyHeight or 2, 0)
                                task.wait(0.1)
                                
                                -- Tame
                                local petName = entity:GetAttribute("PetName") or entity.Name
                                NetworkEngine:Fire("WildPetTame", petName)
                                NetworkEngine:Fire("TamePet", petName)
                                
                                task.wait(0.1)
                                -- Return
                                hrp.CFrame = originalCFrame
                                break -- Tame one at a time to prevent server rejection
                            end
                        end
                    end
                end
            end
        end
    end

    function AutomationCore:RunEconomyAndGuildRoutine()
        if Config.AutoUseDailyDeals then
            NetworkEngine:Fire("UseDailyDealSingle")
            NetworkEngine:Fire("UseDailyDealAll")
        end
        
        if Config.AutoUseDoubleOrNothing then
            local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
            local cash = leaderstats and (leaderstats:FindFirstChild("Cash") or leaderstats:FindFirstChild("Money"))
            if cash and cash.Value >= Config.DoubleOrNothingThreshold then
                NetworkEngine:Fire("DoubleOrNothing", math.floor(cash.Value * 0.1))
            end
        end
        
        if Config.GuildEnabled and Config.GuildAutoClaimRewards then
            NetworkEngine:Fire("GuildClaimRewards")
        end
        
        if Config.AutoSpendSkillPoints then
             NetworkEngine:Fire("SpendSkillPoint", Config.SkillAllocationPriority)
        end
        
        if Config.AutoClaimMail then
            local success, mailList = NetworkEngine:Fire("MailboxList")
            if success and mailList and type(mailList) == "table" then
                for _, mail in ipairs(mailList) do
                    local mailId = mail.id or mail.mailId
                    if mailId then
                        NetworkEngine:Fire("MailboxClaim", mailId)
                    end
                end
            end
        end
    end

