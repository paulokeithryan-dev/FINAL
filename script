local function initializeEnvironmentModifiers()
    -- Event-driven FullBright instead of high-frequency loop threads
    if Config.Environment.FullBright then
        local function matchLighting()
            Lighting.Ambient = Color3.fromRGB(255, 255, 255)
            Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
            Lighting.Brightness = 2
            Lighting.ClockTime = 14
        end
        matchLighting()
        Lighting.Changed:Connect(matchLighting)
    end

    -- Event-driven Infinite Zoom Guard
    if Config.Environment.InfiniteZoom then
        LocalPlayer.CameraMaxZoomDistance = Config.Environment.ZoomDistance
        LocalPlayer:GetPropertyChangedSignal("CameraMaxZoomDistance"):Connect(function()
            if LocalPlayer.CameraMaxZoomDistance ~= Config.Environment.ZoomDistance then
                LocalPlayer.CameraMaxZoomDistance = Config.Environment.ZoomDistance
            end
        end)
    end

    -- Instant Prompt Trigger System via Engine Interception
    if Config.Automation.InstantPrompt then
        ProximityPromptService.PromptButtonHoldBegan:Connect(function(prompt)
            prompt:InputHoldBegin()
            task.wait()
            prompt:InputHoldEnd()
        end)
    end
end

