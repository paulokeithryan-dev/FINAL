local function runPetHuntProtection()
    if not (Config.PetHuntEnabled or Config.ProtectionEnabled) then return end

    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    -- Remove ESP from pets that are no longer in workspace
    for model in pairs(ActiveESP) do
        if not model.Parent or not model:FindFirstChildOfClass("BasePart") then
            clearAllESP()
            break
        end
    end

    local nearestPet, nearestDist = nil, math.huge
    local nearestThief, nearestThiefDist = nil, math.huge
    local isThreatened = false

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end
        local thiefRoot = player.Character:FindFirstChild("HumanoidRootPart")
        if not thiefRoot then continue end

        local thiefDist = (thiefRoot.Position - rootPart.Position).Magnitude
        if thiefDist <= Config.ProtectionRadius then
            isThreatened = true
            if thiefDist < nearestThiefDist then
                nearestThief = player
                nearestThiefDist = thiefDist
            end

            for _, petModel in ipairs(player.Character:GetChildren()) do
                local petRoot = petModel:FindFirstChild("RootPart")
                if not petRoot then petRoot = petModel:FindFirstChildOfClass("BasePart") end
                if not petRoot then continue end

                local petName = petModel:GetAttribute("PetName") or petModel.Name
                local cleanName = string.gsub(string.lower(petName), "%s+", "")

                -- Check if pet is in target list
                local isTarget = false
                for _, pd in ipairs(PetDatabase) do
                    local dbKey = string.lower(string.gsub(pd[2], "%s+", ""))
                    local dbName = string.lower(string.gsub(pd[1], "%s+", ""))
                    if cleanName == dbKey or cleanName == dbName then
                        isTarget = true
                        break
                    end
                end

                if isTarget then
                    local petDist = (petRoot.Position - rootPart.Position).Magnitude
                    if petDist < nearestDist then
                        nearestPet = petRoot
                        nearestDist = petDist
                    end
                    renderPetESP(petModel)
                end
            end
        end
    end

    if isThreatened and nearestPet and nearestThief then
        executeInterceptionManeuver(nearestThief.Character:FindFirstChild("HumanoidRootPart"), nearestPet)
        task.wait(0.5)
    end
end
