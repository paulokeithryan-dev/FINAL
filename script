    -- ============================================================
    local function teleportToLocation(locationName)
        local rootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end

        local target = Workspace:FindFirstChild(locationName)
            or Workspace:FindFirstChild(locationName:lower())

        if not target then
            for _, child in ipairs(Workspace:GetDescendants()) do
                if string.find(child.Name:lower(), locationName:lower()) then
                    target = child; break
                end
            end
        end

        if not target then
            print("[TELEPORT]: Location not found: " .. locationName)
            return
        end

        local targetPos = target:FindFirstChildOfClass("BasePart")
            or target:FindFirstChildOfClass("HumanoidRootPart")
        if not targetPos then return end

        local mode = Config.TeleportMode
        if mode == "Tween" then
            if activeTween then pcall(function() activeTween:Cancel() end) end
            local dist = (rootPart.Position - targetPos.Position).Magnitude
            local duration = math.clamp(dist / Config.TweenSpeed, 0.1, 30)
            activeTween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Quad), {CFrame = targetPos.CFrame * CFrame.new(0, 2, 0)})
            activeTween:Play()
        elseif mode == "CFrame" then
            rootPart.CFrame = targetPos.CFrame * CFrame.new(0, 2, 0)
        elseif mode == "Walk" then
            local path = PathfindingService:CreatePath({AgentRadius = Config.PathfindingRadius, AgentHeight = 5, AgentCanJump = true})
            local success, result = pcall(function()
                path:ComputeAsync(rootPart.Position, targetPos.Position)
                return path.Status == Enum.PathStatus.Success
            end)
            if success and result then
                local waypoints = path:GetWaypoints()
                local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    for _, wp in ipairs(waypoints) do
                        humanoid:MoveTo(wp.Position)
                        humanoid.MoveToFinished:Wait()
                        if wp.Action == Enum.PathWaypointAction.Jump then
                            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                        end
                    end
                end
            end
            pcall(function() path:Destroy() end)
        end
    end

