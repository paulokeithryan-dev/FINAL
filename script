        textLabel.Parent = frame

        local input = Instance.new("TextBox")
        input.Size = UDim2.new(0.55, 0, 1, 0)
        input.Position = UDim2.new(0.45, 0, 0, 0)
        input.BackgroundColor3 = C.InputBg
        input.BorderSizePixel = 0
        input.Text = default or ""
        input.TextColor3 = C.Text
        input.Font = Enum.Font.Gotham
        input.TextSize = 10
        input.PlaceholderText = placeholder or ""
        input.PlaceholderColor3 = C.DimText
        input.Parent = frame
        Instance.new("UICorner").CornerRadius = UDim.new(0, 5)
        Instance.new("UICorner").Parent = input

        local state = {value = input.Text}

        input.FocusLost:Connect(function(enterPressed)
            if enterPressed then
                state.value = input.Text
                if callback then pcall(callback, state.value) end
            end
        end)

        return state
    end

    function UI:CreateButton(parent, label, callback)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 26)
        frame.BackgroundColor3 = C.SectionBg
        frame.BorderSizePixel = 0
        frame.Parent = parent
        Instance.new("UICorner").CornerRadius = UDim.new(0, 6)
        Instance.new("UICorner").Parent = frame

        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.Text = label
        textLabel.TextColor3 = C.Accent
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextSize = 11
        textLabel.Parent = frame

        frame.MouseButton1Click:Connect(function()
            textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            pcall(callback)
            showToast(label)
            task.delay(0.15, function()
                textLabel.TextColor3 = C.Accent
            end)
        end)

        frame.MouseEnter:Connect(function() frame.BackgroundColor3 = C.SliderBg end)
        frame.MouseLeave:Connect(function() frame.BackgroundColor3 = C.SectionBg end)

        return frame
    end

