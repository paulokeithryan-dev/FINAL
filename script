-- ============================================================
-- SECTION 3: CORE NETWORKING ENGINE (PACKET-BASED)
-- ============================================================
-- From compiled.lua analysis: The game uses a single shared RemoteEvent/RemoteFunction
-- for packet-based communication. Packet IDs are strings like "AuctioneerPurchaseLot",
-- "PetHuntJoinQueue", etc., fired through the shared remote.

local NetworkRemote = nil
local PacketCache = {}
local PacketRegistry = {}

-- Resolve the network remote
local function resolveNetworkRemote()
    if NetworkRemote then return NetworkRemote end

    -- Try common names from compiled.lua analysis
    local remote = ReplicatedStorage:FindFirstChild("Network")
    if remote then NetworkRemote = remote; return remote end

    remote = ReplicatedStorage:FindFirstChild("Remote")
    if remote then NetworkRemote = remote; return remote end

    -- Scan for the shared remote event
    for _, child in ipairs(ReplicatedStorage:GetChildren()) do
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            NetworkRemote = child
            return child
        end
    end

    -- Last resort: find any RemoteEvent in ReplicatedStorage descendants
    local allRemotes = ReplicatedStorage:FindFirstChildOfClass("RemoteEvent")
    if allRemotes then NetworkRemote = allRemotes; return allRemotes end

    return nil
end

--- Fire a packet to the server (fire-and-forget or response-based)
--- @param packetName string - The packet ID (e.g., "AuctioneerPurchaseLot")
--- @param ... any - Packet arguments
local function FirePacket(packetName, ...)
    local remote = resolveNetworkRemote()
    if not remote then
        warn("[NETWORK]: No network remote found. Cannot fire packet: " .. packetName)
        return false
    end

    local success, result = pcall(function()
        if remote:IsA("RemoteFunction") then
            return remote:InvokeServer(packetName, ...)
        elseif remote:IsA("RemoteEvent") then
            return remote:FireServer(packetName, ...)
        end
    end)

    if not success then
        warn("[NETWORK]: Failed to fire packet: " .. packetName .. " — " .. tostring(result))
    end

    return success, result
end

--- Fire a packet that expects a server response (Fire + Wait pattern)
local function FireAndWait(packetName, ...)
    return FirePacket(packetName, ...)
end

--- Batch-fire multiple packets for efficiency
local function FirePacketBatch(packets)
    for _, packet in ipairs(packets) do
        FirePacket(packet[1], table.unpack(packet, 2))
    end
end

